":"https://cdn.jsdelivr.net/gh/cyl-ly/picture/blogimage/202312241427715.jpg","link":"/","description":"多读书多看报，少吃零食多睡觉。","socials":{"github":"","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{"bilibili":{"icon":"/svg/bilibili.svg","link":"https://space.bilibili.com/479018557"},"email":{"icon":"/svg/email.svg","link":"mailto:1873378495@qq.com"},"qq":{"icon":"/svg/qq.svg","link":"https://cdn.jsdelivr.net/gh/cyl-ly/picture/blogimage/202312242201293.jpg"},"leetcode":{"icon":"/svg/leetcode.svg","link":"https://leetcode.cn/u/chaiyl/"}}}}}}